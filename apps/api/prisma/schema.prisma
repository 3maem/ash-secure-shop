datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String?
  role      String   @default("user")
  bio       String?
  avatar    String?
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]
}

model Product {
  id          String   @id @default(uuid())
  name        String
  nameAr      String?
  description String?
  price       Float
  image       String?
  stock       Int      @default(100)
  createdAt   DateTime @default(now())
}

model CheckoutSession {
  id             String   @id @default(uuid())
  userId         String
  items          String
  subtotal       Float
  shippingCost   Float?
  total          Float
  address        String?
  shippingMethod String?
  lastProof      String?
  currentStep    Int      @default(1)
  status         String   @default("pending")
  createdAt      DateTime @default(now())
  expiresAt      DateTime
}

model Order {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  items     String
  total     Float
  currency  String   @default("SAR")
  status    String   @default("completed")
  createdAt DateTime @default(now())
}
